---
import { Command } from 'lucide-astro';
const { items = [] } = Astro.props;
---
<dialog id="command-palette" class="w-[min(560px,calc(100%-24px))] rounded-2xl border rule bg-[var(--surface)] p-0 text-[var(--text)] shadow-2xl backdrop:bg-black/40">
  <div class="border-b rule p-4"><label class="sr-only" for="command-search">Search</label><input id="command-search" class="w-full bg-transparent text-lg outline-none" placeholder="Search the archive…" autocomplete="off" /></div>
  <div id="command-results" class="max-h-[55vh] overflow-y-auto p-2" aria-live="polite"></div>
  <div class="flex items-center gap-2 border-t rule p-3 text-xs text-[var(--muted)]"><Command size={14} /> Navigate with ↑ ↓ · Enter to open · Esc to close</div>
</dialog>
<script define:vars={{ items }}>
  const dialog = document.querySelector('#command-palette') as HTMLDialogElement;
  const input = document.querySelector('#command-search') as HTMLInputElement;
  const results = document.querySelector('#command-results') as HTMLElement;
  const render = (query = '') => { const matches = items.filter((item) => item.title.toLowerCase().includes(query.toLowerCase())); results.innerHTML = matches.map((item) => `<a class="flex items-center justify-between rounded-xl px-3 py-3 hover:bg-[var(--accent-soft)]" href="${item.url}"><span>${item.title}</span><span class="text-[var(--muted)]">↵</span></a>`).join('') || '<p class="p-4 text-sm text-[var(--muted)]">No matches found.</p>'; };
  const open = () => { render(input.value); dialog.showModal(); input.focus(); };
  document.querySelectorAll('[data-command-palette]').forEach((button) => button.addEventListener('click', open));
  input.addEventListener('input', () => render(input.value));
  dialog.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
  document.addEventListener('keydown', (event) => { if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') { event.preventDefault(); open(); } if (event.key === 'Escape' && dialog.open) dialog.close(); if (event.key === '?' && document.activeElement?.tagName !== 'INPUT') open(); });
  render();
</script>
