---
import { Search, Sun, Moon, Menu, X } from 'lucide-astro';
---
<header class="sticky top-0 z-30 border-b rule" style="background: color-mix(in srgb, var(--bg) 90%, transparent); backdrop-filter: blur(14px)">
  <div class="container flex h-20 items-center justify-between gap-6">
    <a href="/" class="serif text-2xl font-medium tracking-tight">Gobind Singh</a>
    <nav id="main-nav" class="hidden items-center gap-5 text-sm text-[var(--muted)] lg:flex" aria-label="Main navigation">
      <a href="/words/">Words</a><a href="/hobbies/">Hobbies</a><a href="/takes/">Takes</a><a href="/projects/">Projects</a><a href="/timeline/">Career</a><a href="/now/">Now</a>
    </nav>
    <div class="flex items-center gap-2">
      <button class="icon-button" data-command-palette aria-label="Open command palette"><Search size={18} /></button>
      <button class="icon-button" data-theme-toggle aria-label="Toggle theme"><Sun class="hidden dark:block" size={18} /><Moon class="dark:hidden" size={18} /></button>
      <button class="icon-button lg:hidden" data-menu-toggle aria-expanded="false" aria-controls="main-nav" aria-label="Open navigation"><Menu data-menu-open size={20} /><X class="hidden" data-menu-close size={20} /></button>
    </div>
  </div>
</header>
<script>
  const nav = document.querySelector('#main-nav');
  document.querySelector('[data-menu-toggle]')?.addEventListener('click', (event) => {
    const button = event.currentTarget as HTMLButtonElement;
    const open = button.getAttribute('aria-expanded') !== 'true';
    button.setAttribute('aria-expanded', String(open)); nav?.classList.toggle('hidden', !open); nav?.classList.toggle('flex', open); nav?.classList.toggle('absolute', open); nav?.classList.toggle('top-20', open); nav?.classList.toggle('left-0', open); nav?.classList.toggle('right-0', open); nav?.classList.toggle('container', open);
    button.querySelector('[data-menu-open]')?.classList.toggle('hidden', open); button.querySelector('[data-menu-close]')?.classList.toggle('hidden', !open);
  });
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => { const dark = document.documentElement.classList.toggle('dark'); localStorage.setItem('theme', dark ? 'dark' : 'light'); });
</script>
