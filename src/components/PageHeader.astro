---
const { eyebrow, title, description } = Astro.props;
---
<header class="mb-12 max-w-3xl"><p class="eyebrow mb-4">{eyebrow}</p><h1 class="serif text-5xl leading-[.98] tracking-tight sm:text-7xl">{title}</h1>{description && <p class="mt-6 max-w-2xl text-lg text-[var(--muted)]">{description}</p>}</header>
