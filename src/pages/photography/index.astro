---
import { getCollection } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHeader from '../../components/PageHeader.astro';
const entries = await getCollection('photos');
---
<BaseLayout title="Photography — Gobind Singh"><section class="container py-20 lg:py-32"><PageHeader eyebrow="Photography" title="Places, light, and the stories between." description="A responsive archive for photographs and the details that make them memorable." /><div class="columns-1 gap-5 sm:columns-2">{entries.map((entry) => <figure class="card mb-5 break-inside-avoid overflow-hidden">{entry.data.image ? <img src={entry.data.image} alt={entry.data.alt || entry.data.title} class="w-full" loading="lazy" /> : <div class="p-8"><p class="eyebrow">{entry.data.month}</p><figcaption class="serif mt-3 text-3xl">{entry.data.title}</figcaption><p class="mt-3 text-sm text-[var(--muted)]">{entry.data.description}</p></div>}</figure>)}</div></section></BaseLayout>
