---
import { getCollection, render } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() { return (await getCollection('poetry')).map((entry) => ({ params: { slug: entry.id }, props: { entry } })); }
const { entry } = Astro.props; const { Content } = await render(entry);
---
<BaseLayout title={`${entry.data.title} — Poetry`}><article class="container py-20 lg:py-32"><div class="mx-auto max-w-2xl"><p class="eyebrow">Poetry</p><h1 class="serif mt-5 text-6xl leading-none sm:text-8xl">{entry.data.title}</h1><div class="prose mt-16"><Content /></div><a class="mt-14 inline-block text-sm text-[var(--accent)]" href="/poetry/">← All poems</a></div></article></BaseLayout>
