---
import { getCollection } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import PageHeader from '../../components/PageHeader.astro';
const entries = (await getCollection('takes')).filter((entry) => !entry.data.hidden).sort((a,b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
---
<BaseLayout title="Takes — Gobind Singh"><section class="container py-20 lg:py-32"><PageHeader eyebrow="Takes" title="Opinions I’m willing to defend." description="Rankings, comparisons, recommendations, and arguments about basketball, books, movies, and anything else I find interesting." />{entries.length ? <div class="grid gap-5 md:grid-cols-2">{entries.map((entry) => <a class="card block p-7" href={`/takes/${entry.id}/`}><div class="flex items-center justify-between gap-3"><span class="eyebrow">{entry.data.type}</span>{entry.data.topic && <span class="rounded-full bg-[var(--accent-soft)] px-3 py-1 text-xs text-[var(--accent)]">{entry.data.topic}</span>}</div><h2 class="serif mt-5 text-3xl">{entry.data.title}</h2><p class="mt-3 text-[var(--muted)]">{entry.data.description}</p><span class="mt-6 inline-block text-sm text-[var(--accent)]">Read the take →</span></a>)}</div> : <div class="card mx-auto max-w-2xl p-8 text-center sm:p-12"><p class="text-4xl">💭</p><h2 class="serif mt-5 text-4xl">The takes are loading.</h2><p class="mt-4 text-[var(--muted)]">This is where I’ll rank, compare, recommend, and make the occasional argument. New takes will be added as Markdown files.</p></div>}</section></BaseLayout>
